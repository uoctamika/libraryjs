{
  "name": "@uoctamika/libraryjs",
  "version": "1.1.2",
  "description": " A lightweight JavaScript & TypeScript utility library - just import and use. No configuration needed, functions are ready to use",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json && npm run rename:mjs",
    "rename:mjs": "find dist/esm -name '*.js' -exec sh -c 'mv \"$0\" \"${0%.js}.mjs\"' {} \\; && find dist/esm -name '*.mjs' -exec sed -i \"s/from '\\\\(.*\\\\)\\\\.js'/from '\\\\1.mjs'/g\" {} \\;",
    "clean": "rm -rf dist",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uoctamika/libraryjs.git"
  },
  "bugs": {
    "url": "https://github.com/uoctamika/libraryjs/issues"
  },
  "homepage": "https://github.com/uoctamika/libraryjs#readme",
  "keywords": [
    "utility",
    "typescript",
    "javascript",
    "library",
    "readyToUse",
    "buildInFunction"
  ],
  "author": {
    "name": "Uoc Tamika",
    "email": "uocdev.github.io@gmail.com",
    "url": "https://github.com/uoctamika"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
