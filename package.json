{
  "name": "@uoctamika/libraryjs",
  "version": "1.2.2",
  "description": " A lightweight JavaScript & TypeScript utility library - just import and use. No configuration needed, functions are ready to use",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:cjs && npm run build:esm && npm run rename:mjs",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "rename:mjs": "find dist/esm -name '*.js' -exec sh -c 'mv \"$0\" \"${0%.js}.mjs\"' {} \\; && find dist/esm -name '*.mjs' -exec sed -i \"s/from '\\\\(.*\\\\)\\\\.js'/from '\\\\1.mjs'/g\" {} \\;",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
   "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uoctamika/libraryjs.git"
  },
  "bugs": {
    "url": "https://github.com/uoctamika/libraryjs/issues"
  },
  "homepage": "https://github.com/uoctamika/libraryjs#readme",
  "keywords": [
    "utility",
    "typescript",
    "javascript",
    "library",
    "readyToUse",
    "buildInFunction"
  ],
  "author": {
    "name": "Uoc Tamika",
    "email": "uocdev.github.io@gmail.com",
    "url": "https://github.com/uoctamika"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
